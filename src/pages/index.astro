---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import avatar from '../assets/noah-avatar.jpg';
import imscPhoto from '../assets/imsc-macau-2026.jpg';

const year = new Date().getFullYear();
const description = 'Explore Noah Xu’s pixel room — a one-screen interactive profile about code, competitions, sport, music and life in Macau.';

const dockItems = [
  { id: 'about', icon: 'NX', en: 'Profile', zh: '關於' },
  { id: 'projects', icon: '</>', en: 'Builds', zh: '作品' },
  { id: 'imsc', icon: 'Σ', en: 'IMSC', zh: '數學' },
  { id: 'life', icon: '●', en: 'Life', zh: '生活' },
  { id: 'contact', icon: '@', en: 'Contact', zh: '聯絡' }
];
---

<Layout title="Noah_Xu — Interactive Pixel Profile" description={description} image={avatar.src}>
  <div class="profile-app">
    <a class="skip-link" href="#room-title">Skip to profile / 跳至主頁</a>

    <header class="app-bar" aria-label="Profile controls">
      <a class="pixel-brand" href="#home" aria-label="Noah Xu home">
        <span class="brand-led" aria-hidden="true"></span>
        <span>NOAH_XU.EXE</span>
      </a>

      <div class="app-status">
        <span class="status-dot" aria-hidden="true"></span>
        <span class="lang-en">ONLINE · MACAU</span>
        <span class="lang-zh">在線 · 澳門</span>
      </div>

      <div class="bar-actions">
        <a class="bar-button" href="https://github.com/noah200910070082-dotcom" target="_blank" rel="noreferrer">GitHub ↗</a>
        <button class="bar-button language-switch" type="button" aria-label="Switch language">
          <span class="lang-en">中文</span><span class="lang-zh">EN</span>
        </button>
      </div>
    </header>

    <main class="room-shell" id="home">
      <section class="pixel-room" aria-labelledby="room-title">
        <div class="wall-grid" aria-hidden="true"></div>
        <div class="window-scene" aria-hidden="true">
          <span class="moon"></span>
          <span class="building building-one"></span>
          <span class="building building-two"></span>
          <span class="building building-three"></span>
        </div>

        <div class="room-heading">
          <p class="room-kicker">WELCOME TO MY ROOM</p>
          <h1 id="room-title">NOAH_XU</h1>
          <p class="room-subtitle lang-en">Student developer · competitor · player · musician</p>
          <p class="room-subtitle lang-zh">學生開發者 · 競賽選手 · 運動玩家 · 音樂人</p>
          <p class="room-hint lang-en">Click an object or use the dock to explore.</p>
          <p class="room-hint lang-zh">點擊房間物件，或使用下方快捷列探索。</p>
        </div>

        <button class="scene-button portrait-object" type="button" data-open="about" aria-label="Open Noah profile">
          <span class="picture-nail" aria-hidden="true"></span>
          <span class="picture-frame">
            <Image src={avatar} alt="Noah Xu as a child" widths={[180, 300]} sizes="150px" format="webp" loading="eager" />
          </span>
          <span class="object-label"><span class="lang-en">PROFILE</span><span class="lang-zh">關於我</span></span>
        </button>

        <button class="scene-button desk-object" type="button" data-open="projects" aria-label="Open projects">
          <span class="computer">
            <span class="monitor"><span class="screen"><b>NOAH</b><i>READY_</i></span></span>
            <span class="computer-neck"></span>
            <span class="keyboard"></span>
          </span>
          <span class="desk"><i></i><i></i></span>
          <span class="object-label"><span class="lang-en">PROJECTS</span><span class="lang-zh">作品</span></span>
        </button>

        <button class="scene-button imsc-object" type="button" data-open="imsc" aria-label="Open IMSC experience">
          <span class="clipboard"><i></i><b>Σ</b><em>2026</em></span>
          <span class="object-label">IMSC</span>
        </button>

        <button class="scene-button lamp-object" type="button" data-open="contact" aria-label="Open contact information">
          <span class="lamp-shade"></span>
          <span class="lamp-light"></span>
          <span class="lamp-stem"></span>
          <span class="lamp-base"></span>
          <span class="object-label"><span class="lang-en">SAY HI</span><span class="lang-zh">來聊聊</span></span>
        </button>

        <button class="scene-button shelf-object" type="button" data-open="life" aria-label="Open life outside code">
          <span class="shelf-top"></span>
          <span class="shelf-row row-one"><i></i><i></i><i></i><i></i></span>
          <span class="shelf-row row-two"><i></i><i></i><i></i><i></i><i></i></span>
          <span class="shelf-row row-three"><i></i><i></i><i></i></span>
          <span class="object-label"><span class="lang-en">OFF-SCREEN</span><span class="lang-zh">屏幕之外</span></span>
        </button>

        <div class="cat-object" aria-hidden="true">
          <span class="cat-tail"></span><span class="cat-body"></span><span class="cat-head"><i></i><i></i></span>
        </div>

        <button class="scene-button hobby-object tennis-object" type="button" data-open="life" aria-label="Open tennis profile">
          <span class="racket"><i></i></span><span class="ball"></span>
          <span class="object-label">TENNIS</span>
        </button>

        <button class="scene-button hobby-object go-object" type="button" data-open="life" aria-label="Open Go profile">
          <span class="go-board"><i></i><i></i><i></i><i></i><b></b><em></em></span>
          <span class="object-label"><span class="lang-en">GO 3-DAN</span><span class="lang-zh">圍棋三段</span></span>
        </button>

        <button class="scene-button hobby-object violin-object" type="button" data-open="life" aria-label="Open music profile">
          <span class="violin-case"><i></i><b>♪</b></span>
          <span class="object-label"><span class="lang-en">MUSIC</span><span class="lang-zh">音樂</span></span>
        </button>

        <div class="floor" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span>
        </div>

        <nav class="quick-dock" aria-label="Profile branches">
          {dockItems.map((item) => (
            <button class="dock-item" type="button" data-open={item.id} aria-label={`Open ${item.en}`}>
              <span class="dock-icon">{item.icon}</span>
              <span class="dock-label lang-en">{item.en}</span>
              <span class="dock-label lang-zh">{item.zh}</span>
            </button>
          ))}
        </nav>
      </section>
    </main>

    <footer class="room-footer">
      <p><span class="lang-en">桃李春风一杯酒，江湖夜雨十年灯。</span><span class="lang-zh">WHAT DOESN’T KILL YOU MAKES YOU STRONGER.</span></p>
      <p>© {year} · <span class="lang-en">MADE IN MACAU</span><span class="lang-zh">澳門製造</span></p>
    </footer>

    <dialog class="pixel-dialog" id="about">
      <article class="dialog-window">
        <header class="window-bar">
          <span>PROFILE.TXT</span>
          <button type="button" data-close aria-label="Close profile">×</button>
        </header>
        <div class="window-content about-layout">
          <figure class="dialog-photo">
            <Image src={avatar} alt="Noah Xu childhood portrait" widths={[360, 600]} sizes="280px" format="webp" />
            <figcaption>ORIGINAL BETA BUILD · 180 CM OF CURIOSITY</figcaption>
          </figure>
          <div>
            <p class="terminal-line">C:\USERS\NOAH&gt; WHOAMI</p>
            <h2>NOAH_XU</h2>
            <p class="lead lang-en">Macau-born student at Hou Kong Middle School. Developer, OI / AI competitor, social human and professional tab-opener.</p>
            <p class="lead lang-zh">土生土長的澳門濠江中學生。開發者、OI / AI 競賽選手、喜歡交流的人，以及專業分頁開啟者。</p>
            <div class="data-grid">
              <span><small>HOME</small><b>Macau · MO</b></span>
              <span><small>SCHOOL</small><b><span class="lang-en">Hou Kong</span><span class="lang-zh">濠江中學</span></b></span>
              <span><small>ARENA</small><b>OI · AI · Math</b></span>
              <span><small>NORTH STAR</small><b><span class="lang-en">Peking University</span><span class="lang-zh">北京大學</span></b></span>
            </div>
            <blockquote>桃李春风一杯酒，江湖夜雨十年灯。</blockquote>
          </div>
        </div>
      </article>
    </dialog>

    <dialog class="pixel-dialog" id="projects">
      <article class="dialog-window">
        <header class="window-bar">
          <span>PROJECTS.APP</span>
          <button type="button" data-close aria-label="Close projects">×</button>
        </header>
        <div class="window-content">
          <p class="terminal-line">C:\NOAH\BUILD&gt; DIR</p>
          <h2><span class="lang-en">Things I build</span><span class="lang-zh">我做的東西</span></h2>
          <div class="project-list">
            <a class="project-row featured" href="https://houkong.up.railway.app" target="_blank" rel="noreferrer">
              <span class="project-number">01</span>
              <span><b>濠江通</b><small><span class="lang-en">Sports Day Management Assistant</span><span class="lang-zh">校運會管理助手</span></small></span>
              <em>OPEN ↗</em>
            </a>
            <div class="project-row">
              <span class="project-number">02</span>
              <span><b><span class="lang-en">AI Relay Station</span><span class="lang-zh">AI 中轉站</span></b><small><span class="lang-en">Useful AI capabilities, connected</span><span class="lang-zh">連接實用的 AI 能力</span></small></span>
              <em>WIP···</em>
            </div>
          </div>
          <p class="window-note lang-en">Real projects first. Fancy descriptions later.</p>
          <p class="window-note lang-zh">先做真正有用的項目，華麗描述可以晚一點。</p>
        </div>
      </article>
    </dialog>

    <dialog class="pixel-dialog" id="imsc">
      <article class="dialog-window wide-window">
        <header class="window-bar">
          <span>IMSC_2026.JPG</span>
          <button type="button" data-close aria-label="Close IMSC experience">×</button>
        </header>
        <div class="window-content imsc-layout">
          <figure class="imsc-photo">
            <Image src={imscPhoto} alt="Macau delegation at the fourth International Mathematics Summer Camp" widths={[620, 1000, 1400]} sizes="(max-width: 700px) 90vw, 55vw" format="webp" />
          </figure>
          <div>
            <p class="terminal-line">EVENT LOG · 2026</p>
            <h2>IMSC</h2>
            <h3 class="lang-en">Math, teamwork and a bigger map.</h3>
            <h3 class="lang-zh">數學、同行，與更大的世界。</h3>
            <p class="lang-en">Represented Macau at the 4th International Mathematics Summer Camp.</p>
            <p class="lang-zh">代表澳門參與第四屆國際數學夏令營。</p>
            <span class="achievement-chip">MACAU DELEGATION · 2026</span>
          </div>
        </div>
      </article>
    </dialog>

    <dialog class="pixel-dialog" id="life">
      <article class="dialog-window wide-window">
        <header class="window-bar">
          <span>OFF_SCREEN.EXE</span>
          <button type="button" data-close aria-label="Close life profile">×</button>
        </header>
        <div class="window-content">
          <p class="terminal-line">C:\NOAH\LIFE&gt; LIST --ALL</p>
          <h2><span class="lang-en">More than code</span><span class="lang-zh">代碼之外</span></h2>
          <div class="hobby-grid">
            <article><span>◎</span><small>TENNIS</small><b><span class="lang-en">One more ball.</span><span class="lang-zh">再多救一球。</span></b><p><span class="lang-en">Djokovic energy: patient feet, stubborn mind.</span><span class="lang-zh">德約科維奇式能量：耐心腳步，倔強意志。</span></p></article>
            <article><span>●</span><small>GO</small><b><span class="lang-en">3-dan player</span><span class="lang-zh">圍棋三段</span></b><p><span class="lang-en">See the whole board. Place one stone.</span><span class="lang-zh">看全局，落一子。</span></p></article>
            <article><span>♪</span><small>VIOLIN</small><b><span class="lang-en">Strings & patience</span><span class="lang-zh">琴弦與耐心</span></b><p><span class="lang-en">Not everything needs to be rushed.</span><span class="lang-zh">不是所有事情都需要趕。</span></p></article>
            <article><span>↗</span><small>TRAVEL</small><b><span class="lang-en">New maps, new people</span><span class="lang-zh">新地圖，新朋友</span></b><p><span class="lang-en">Curiosity works better outside the room too.</span><span class="lang-zh">走出房間，好奇心依然有效。</span></p></article>
          </div>
        </div>
      </article>
    </dialog>

    <dialog class="pixel-dialog" id="contact">
      <article class="dialog-window">
        <header class="window-bar">
          <span>CONTACTS.LNK</span>
          <button type="button" data-close aria-label="Close contacts">×</button>
        </header>
        <div class="window-content">
          <p class="terminal-line">PING NOAH_XU</p>
          <h2><span class="lang-en">Let’s connect.</span><span class="lang-zh">來聊聊。</span></h2>
          <p class="lead lang-en">Code, competitions, tennis, music, travel — or something not on the menu yet.</p>
          <p class="lead lang-zh">代碼、競賽、網球、音樂、旅行，或任何還沒出現在選單裡的新話題。</p>
          <div class="contact-list">
            <a href="https://github.com/noah200910070082-dotcom" target="_blank" rel="noreferrer"><span>GitHub</span><b>noah200910070082-dotcom</b><em>↗</em></a>
            <a href="https://www.instagram.com/noah_chanwa/" target="_blank" rel="noreferrer"><span>Instagram</span><b>@noah_chanwa</b><em>↗</em></a>
            <button class="copy-handle" type="button" data-copy="Noah107"><span>WeChat</span><b>Noah107</b><em>COPY</em></button>
            <button class="copy-handle" type="button" data-copy="noah_xu_50118"><span>Discord</span><b>noah_xu_50118</b><em>COPY</em></button>
          </div>
        </div>
      </article>
    </dialog>

    <div class="toast" role="status" aria-live="polite">
      <span class="lang-en">Copied to clipboard.</span><span class="lang-zh">已複製到剪貼板。</span>
    </div>
  </div>

  <script>
    const html = document.documentElement;
    const languageButton = document.querySelector<HTMLButtonElement>('.language-switch');
    const toast = document.querySelector<HTMLElement>('.toast');
    const dialogs = Array.from(document.querySelectorAll<HTMLDialogElement>('.pixel-dialog'));

    const updateLanguageLabel = () => {
      const isChinese = html.dataset.language === 'zh';
      languageButton?.setAttribute('aria-label', isChinese ? 'Switch to English' : '切換至中文');
    };

    languageButton?.addEventListener('click', () => {
      const next = html.dataset.language === 'zh' ? 'en' : 'zh';
      html.dataset.language = next;
      html.lang = next === 'zh' ? 'zh-Hant' : 'en';
      localStorage.setItem('noah-language', next);
      updateLanguageLabel();
    });

    const openDialog = (id: string, updateHash = true) => {
      const dialog = document.getElementById(id) as HTMLDialogElement | null;
      if (!dialog) return;
      dialogs.forEach((item) => {
        if (item !== dialog && item.open) item.close();
      });
      if (!dialog.open) dialog.showModal();
      if (updateHash) history.replaceState(null, '', `#${id}`);
    };

    const closeDialog = (dialog: HTMLDialogElement) => {
      dialog.close();
      history.replaceState(null, '', '#home');
    };

    document.querySelectorAll<HTMLElement>('[data-open]').forEach((button) => {
      button.addEventListener('click', () => openDialog(button.dataset.open || ''));
    });

    document.querySelectorAll<HTMLButtonElement>('[data-close]').forEach((button) => {
      button.addEventListener('click', () => {
        const dialog = button.closest<HTMLDialogElement>('dialog');
        if (dialog) closeDialog(dialog);
      });
    });

    dialogs.forEach((dialog) => {
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) closeDialog(dialog);
      });
      dialog.addEventListener('close', () => {
        if (location.hash === `#${dialog.id}`) history.replaceState(null, '', '#home');
      });
    });

    const copyText = async (value: string) => {
      try {
        await navigator.clipboard.writeText(value);
        return true;
      } catch {
        const temporary = document.createElement('textarea');
        temporary.value = value;
        temporary.setAttribute('readonly', '');
        temporary.style.position = 'fixed';
        temporary.style.opacity = '0';
        document.body.appendChild(temporary);
        temporary.select();
        const legacyCopy = (document as unknown as { execCommand: (command: string) => boolean }).execCommand;
        const copied = legacyCopy.call(document, 'copy');
        temporary.remove();
        return copied;
      }
    };

    document.querySelectorAll<HTMLButtonElement>('.copy-handle').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.dataset.copy;
        if (!value || !(await copyText(value))) return;
        toast?.classList.add('is-visible');
        window.setTimeout(() => toast?.classList.remove('is-visible'), 1600);
      });
    });

    const initialBranch = location.hash.slice(1);
    if (initialBranch && initialBranch !== 'home') openDialog(initialBranch, false);
    updateLanguageLabel();
  </script>

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Noah Xu',
    url: 'https://noahxu.org',
    homeLocation: { '@type': 'Place', name: 'Macau' },
    affiliation: { '@type': 'EducationalOrganization', name: 'Hou Kong Middle School' },
    sameAs: ['https://github.com/noah200910070082-dotcom', 'https://www.instagram.com/noah_chanwa/'],
    knowsAbout: ['Software development', 'Artificial intelligence', 'Olympiad in Informatics', 'Go', 'Violin', 'Tennis']
  })} />
</Layout>
