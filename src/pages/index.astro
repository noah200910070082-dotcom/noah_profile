  <script>
    const html = document.documentElement;
    const languageButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-language-option]'));
    const menuButton = document.querySelector<HTMLButtonElement>('.menu-toggle');
    const navLinks = document.querySelector<HTMLElement>('.nav-links');
    const toast = document.querySelector<HTMLElement>('.toast');

    const setLanguage = (language: string, persist = true) => {
      const next = language === 'zh-hans' || language === 'zh-hant' ? language : 'en';
      html.dataset.language = next;
      html.lang = next === 'zh-hans' ? 'zh-Hans' : next === 'zh-hant' ? 'zh-Hant' : 'en';
      languageButtons.forEach((button) => {
        const active = button.dataset.languageOption === next;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      });
      if (persist) localStorage.setItem('noah-language', next);
    };

    languageButtons.forEach((button) => button.addEventListener('click', () => setLanguage(button.dataset.languageOption || 'en')));

    menuButton?.addEventListener('click', () => {
      const open = navLinks?.classList.toggle('is-open') ?? false;
      menuButton.setAttribute('aria-expanded', String(open));
      menuButton.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
    });

    navLinks?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('is-open');
        menuButton?.setAttribute('aria-expanded', 'false');
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach((element) => observer.observe(element));

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const finePointer = window.matchMedia('(pointer: fine)').matches;
    const ambientLayer = document.querySelector<HTMLElement>('.ambient-layer');

    if (!reducedMotion && finePointer) {
      const interactiveCards = document.querySelectorAll<HTMLElement>('.portrait-card, .about-panel, .work-card, .life-card, .explore-card, .contact-card');
      let activeCard: HTMLElement | null = null;

      const resetCard = (card: HTMLElement) => {
        card.classList.remove('is-interacting');
        card.style.setProperty('--tilt-x', '0deg');
        card.style.setProperty('--tilt-y', '0deg');
        card.style.setProperty('--glow-x', '50%');
        card.style.setProperty('--glow-y', '50%');
        if (activeCard === card) activeCard = null;
      };

      interactiveCards.forEach((card) => {
        card.classList.add('interactive-card');
        const light = document.createElement('span');
        light.className = 'interaction-light';
        light.setAttribute('aria-hidden', 'true');
        card.append(light);

        const strength = card.classList.contains('portrait-card') ? 16 : card.classList.contains('work-card') ? 12 : card.classList.contains('life-card') ? 10 : card.classList.contains('explore-card') ? 9 : 6.5;

        card.addEventListener('pointermove', (event) => {
          if (activeCard && activeCard !== card) resetCard(activeCard);
          activeCard = card;
          card.classList.add('is-interacting');
          const bounds = card.getBoundingClientRect();
          const x = Math.min(1, Math.max(0, (event.clientX - bounds.left) / bounds.width));
          const y = Math.min(1, Math.max(0, (event.clientY - bounds.top) / bounds.height));
          card.style.setProperty('--tilt-x', `${(0.5 - y) * strength}deg`);
          card.style.setProperty('--tilt-y', `${(x - 0.5) * strength}deg`);
          card.style.setProperty('--glow-x', `${x * 100}%`);
          card.style.setProperty('--glow-y', `${y * 100}%`);
        });

        card.addEventListener('pointerleave', () => resetCard(card));
      });

      let ambientFrame = 0;
      let pointerX = 0;
      let pointerY = 0;
      window.addEventListener('pointermove', (event) => {
        const eventTarget = event.target;
        if (activeCard && eventTarget instanceof Node && !activeCard.contains(eventTarget)) resetCard(activeCard);
        pointerX = event.clientX;
        pointerY = event.clientY;
        if (ambientFrame) return;
        ambientFrame = requestAnimationFrame(() => {
          ambientFrame = 0;
          const shiftX = (pointerX / window.innerWidth - 0.5) * -32;
          const shiftY = (pointerY / window.innerHeight - 0.5) * -24;
          ambientLayer?.style.setProperty('--ambient-x', `${shiftX}px`);
          ambientLayer?.style.setProperty('--ambient-y', `${shiftY}px`);
          html.style.setProperty('--scene-x', `${shiftX * 0.38}px`);
          html.style.setProperty('--scene-y', `${shiftY * 0.32}px`);
        });
      }, { passive: true });
    }

    const copyText = async (value: string) => {
      try {
        await navigator.clipboard.writeText(value);
        return true;
      } catch {
        const temporary = document.createElement('textarea');
        temporary.value = value;
        temporary.setAttribute('readonly', '');
        temporary.style.position = 'fixed';
        temporary.style.opacity = '0';
        document.body.appendChild(temporary);
        temporary.select();
        const legacyCopy = (document as unknown as { execCommand: (command: string) => boolean }).execCommand;
        const copied = legacyCopy.call(document, 'copy');
        temporary.remove();
        return copied;
      }
    };

    document.querySelectorAll<HTMLButtonElement>('.copy-handle').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.dataset.copy;
        if (!value) return;
        const copied = await copyText(value);
        if (copied) {
          toast?.classList.add('is-visible');
          window.setTimeout(() => toast?.classList.remove('is-visible'), 1800);
        }
      });
    });

    setLanguage(html.dataset.language || 'en', false);
  </script>

