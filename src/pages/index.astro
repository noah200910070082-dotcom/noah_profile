---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import imscPhoto from '../assets/imsc-macau-2026.jpg';
import pixelCover from '../assets/pixel-cover.png';
import pixelBuild from '../assets/pixel-build.png';

const description = 'Noah Xu’s interactive pixel-world profile — explore projects, competitions, sport, music and life in Macau.';

const buildCards = [
  { id: 'houkong', pos: 'board-one', icon: '⌘', en: 'Hou Kong Pass', zh: '濠江通', enNote: 'Sports day assistant', zhNote: '校運會管理助手' },
  { id: 'ai-hub', pos: 'board-two', icon: 'AI', en: 'AI Relay Hub', zh: 'AI 中轉站', enNote: 'Useful tools, connected', zhNote: '連接實用 AI 能力' },
  { id: 'imsc', pos: 'board-three', icon: 'Σ', en: 'IMSC 2026', zh: '國際數學夏令營', enNote: 'Macau delegation', zhNote: '澳門代表隊' },
  { id: 'tennis', pos: 'board-four', icon: '◎', en: 'Tennis', zh: '網球', enNote: 'One more ball', zhNote: '再多救一球' },
  { id: 'go', pos: 'board-five', icon: '●', en: 'Go · 3 Dan', zh: '圍棋三段', enNote: 'See the whole board', zhNote: '看全局，落一子' },
  { id: 'music', pos: 'board-six', icon: '♪', en: 'Music & Miles', zh: '音樂與旅行', enNote: 'Violin · travel', zhNote: '小提琴 · 旅行' }
];

const detailDialogs = [
  {
    id: 'about', file: 'ABOUT_NOAH.TXT', icon: 'NX',
    enTitle: 'Hello, I’m Noah Xu.', zhTitle: '你好，我是 Noah Xu。',
    enBody: 'A Macau-born student at Hou Kong Middle School — developer, OI / AI competitor, tennis player, Go 3-dan, violinist and a person who genuinely enjoys meeting people.',
    zhBody: '土生土長的澳門濠江中學生：開發者、OI / AI 競賽選手、網球玩家、圍棋三段、小提琴手，也是一個真心喜歡認識新朋友的人。',
    chips: ['MACAU · MO', 'HOU KONG', '180 CM', 'PKU · NORTH STAR']
  },
  {
    id: 'houkong', file: 'HOUKONG.APP', icon: '⌘',
    enTitle: 'Hou Kong Pass', zhTitle: '濠江通',
    enBody: 'A school sports-day management assistant designed around real coordination work. The goal: turn a complicated event flow into a clearer digital process.',
    zhBody: '圍繞校運會真實協調流程設計的管理助手，目標是把複雜活動整理成更清晰的數字化操作。',
    chips: ['PRODUCT', 'SCHOOL OPS', 'WEB'],
    link: 'https://houkong.up.railway.app', linkEn: 'Open deployment', linkZh: '查看部署'
  },
  {
    id: 'ai-hub', file: 'AI_RELAY.WIP', icon: 'AI',
    enTitle: 'AI Relay Hub', zhTitle: 'AI 中轉站',
    enBody: 'A work-in-progress place for connecting useful AI capabilities. Less wandering between tools; more time making useful things.',
    zhBody: '一個正在完善的 AI 能力中轉站：少一點在工具之間繞路，多一點真正有用的創作。',
    chips: ['AI', 'BUILDING', 'COMING SOON']
  },
  {
    id: 'tennis', file: 'TENNIS.LOG', icon: '◎',
    enTitle: 'One more ball.', zhTitle: '再多救一球。',
    enBody: 'I like Djokovic because the point is never over until it is over. Tennis teaches patient feet, a stubborn mind and how to reset after every mistake.',
    zhBody: '我喜歡德約科維奇，因為在最後一刻之前，每一分都還沒有結束。網球教我耐心移動、保持韌性，以及犯錯後重新開始。',
    chips: ['TENNIS', 'DJOKOVIC', 'LONG RALLY']
  },
  {
    id: 'go', file: 'GO_BOARD.SGF', icon: '●',
    enTitle: 'Go · 3 Dan', zhTitle: '圍棋三段',
    enBody: 'A board can look quiet while a hundred possibilities are moving underneath. See the whole board, then place one stone well.',
    zhBody: '棋盤表面很安靜，底下卻同時流動着上百種可能。先看全局，再把一顆棋下好。',
    chips: ['3 DAN', 'STRATEGY', 'PATIENCE']
  },
  {
    id: 'music', file: 'OFF_SCREEN.PLAY', icon: '♪',
    enTitle: 'Music, violin and new maps.', zhTitle: '音樂、琴弦與新地圖。',
    enBody: 'Violin reminds me that not everything should be rushed. Travel reminds me that every map becomes more interesting once there are people and stories on it.',
    zhBody: '小提琴提醒我，不是所有事情都需要趕。旅行則提醒我：地圖上有了人與故事，才真正變得有趣。',
    chips: ['VIOLIN', 'MUSIC', 'TRAVEL', 'PEOPLE']
  },
  {
    id: 'notes', file: 'NOTES.MD', icon: '▤',
    enTitle: 'Learning notes are loading…', zhTitle: '學習筆記正在載入……',
    enBody: 'This branch will collect small discoveries from web development, algorithms, AI competitions and everything learned by building in public.',
    zhBody: '這個分支將記錄 Web 開發、演算法、AI 競賽，以及公開做項目過程中的小發現。',
    chips: ['WEB', 'OI', 'AI', 'LEARNING IN PUBLIC']
  },
  {
    id: 'projects-index', file: 'PROJECTS.MAP', icon: '▰',
    enTitle: 'Projects live on the build map.', zhTitle: '作品在建造地圖裡。',
    enBody: 'Use the wooden “Let’s build!” sign on the right side of the home scene to enter the project world. The map keeps this profile feeling like one interactive page, not a normal website menu.',
    zhBody: '點主畫面右側的「Let’s build!」木牌進入作品世界。這樣整個 profile 會更像一個互動單頁，而不是普通網站選單。',
    chips: ['ONE PAGE', 'PROJECT MAP', 'PIXEL PROFILE']
  }
];
---

<Layout title="Noah_Xu — Pixel World" description={description} image={pixelCover.src}>
  <div class="world-app">
    <main class="scene-viewport" aria-label="Noah Xu interactive pixel profile">
      <section class="world-scene is-active" id="cover-scene" data-scene-panel="home" aria-label="Pixel world home" style={`--hotspot-scene: url('${pixelCover.src}')`}>
        <div class="scene-art">
          <Image src={pixelCover} alt="A warm pixel-art landscape with a developer, cat, bench and large tree" widths={[900, 1400, 1746]} sizes="100vw" format="webp" quality={95} loading="eager" />
        </div>

        <div class="cover-copy">
          <p class="tiny-label">HELLO, WORLD!</p>
          <h1><span class="lang-en">Hi, I’m Noah Xu 👋</span><span class="lang-zh">你好，我是 Noah Xu 👋</span></h1>
          <p><span class="lang-en">I build, compete, play and keep exploring.</span><span class="lang-zh">我寫代碼、打競賽、運動，也一直探索。</span></p>
          <nav class="cover-nav" aria-label="Main profile navigation">
            <button type="button" data-open="about"><span>♙</span><b><span class="lang-en">About</span><span class="lang-zh">關於</span></b></button>
            <button type="button" data-open="projects-index"><span>▰</span><b><span class="lang-en">Projects</span><span class="lang-zh">作品</span></b></button>
            <button type="button" data-open="notes"><span>▤</span><b><span class="lang-en">Notes</span><span class="lang-zh">筆記</span></b></button>
            <button type="button" data-open="contact"><span>✉</span><b><span class="lang-en">Contact</span><span class="lang-zh">聯絡</span></b></button>
          </nav>
        </div>

        <button class="image-hotspot lets-build-hotspot" type="button" data-scene="build" aria-label="Enter the build scene">
          <span><span class="lang-en">ENTER</span><span class="lang-zh">進入作品世界</span> →</span>
        </button>
        <button class="image-hotspot character-hotspot" type="button" data-open="about" aria-label="Meet Noah"></button>
        <button class="image-hotspot cat-hotspot" type="button" data-egg="cat" aria-label="Pet the pixel cat"></button>
        <button class="image-hotspot tree-hotspot" type="button" data-egg="tree" aria-label="Inspect the pixel tree"></button>
        <button class="image-hotspot lake-hotspot" type="button" data-egg="lake" aria-label="Inspect the lake"></button>

        <a class="image-hotspot social-hotspot social-github" href="https://github.com/noah200910070082-dotcom" target="_blank" rel="noreferrer" aria-label="Open GitHub"></a>
        <a class="image-hotspot social-hotspot social-instagram" href="https://www.instagram.com/noah_chanwa/" target="_blank" rel="noreferrer" aria-label="Open Instagram"></a>
        <button class="image-hotspot social-hotspot social-wechat copy-handle" type="button" data-copy="Noah107" aria-label="Copy WeChat"></button>
        <button class="image-hotspot social-hotspot social-discord copy-handle" type="button" data-copy="noah_xu_50118" aria-label="Copy Discord"></button>

        <div class="cover-signature">© 2026 NOAH_XU · MACAU</div>
      </section>

      <section class="world-scene" id="build-scene" data-scene-panel="build" aria-label="Project landscape" aria-hidden="true" style={`--hotspot-scene: url('${pixelBuild.src}')`}>
        <div class="scene-art">
          <Image src={pixelBuild} alt="A pixel-art mountain landscape with project signboards, a developer, cat and large tree" widths={[900, 1400, 1746]} sizes="100vw" format="webp" quality={95} />
        </div>

        <button class="image-hotspot back-home-hotspot" type="button" data-scene="home" aria-label="Back to home"></button>

        {buildCards.map((card) => (
          <button class={`build-card ${card.pos}`} type="button" data-open={card.id} aria-label={`Open ${card.en}`}>
            <span class="board-face">
              <i>{card.icon}</i>
              <span><b class="lang-en">{card.en}</b><b class="lang-zh">{card.zh}</b><small class="lang-en">{card.enNote}</small><small class="lang-zh">{card.zhNote}</small></span>
            </span>
          </button>
        ))}

        <button class="image-hotspot build-tree-hotspot" type="button" data-egg="treehouse" aria-label="Inspect the treehouse"></button>
        <button class="image-hotspot orange-bird-hotspot" type="button" data-egg="orange-bird" aria-label="Spot the orange bird"></button>
        <button class="image-hotspot white-bird-hotspot" type="button" data-egg="white-bird" aria-label="Spot the white bird"></button>
        <button class="image-hotspot mushroom-hotspot" type="button" data-egg="mushroom" aria-label="Inspect the mushroom"></button>
        <button class="image-hotspot deer-hotspot" type="button" data-egg="deer" aria-label="Spot the deer"></button>
        <button class="image-hotspot build-cat-hotspot" type="button" data-egg="build-cat" aria-label="Pet the hiking cat"></button>

        <div class="build-signature">© 2026 NOAH_XU · BUILD TOGETHER</div>
      </section>

      <div class="mobile-scene-nav cover-mobile-nav" data-mobile-nav="home">
        <strong>NOAH_XU · MACAU</strong>
        <button type="button" data-open="about">ABOUT</button>
        <button type="button" data-scene="build">LET’S BUILD →</button>
        <button type="button" data-open="contact">CONTACT</button>
      </div>
      <div class="mobile-scene-nav build-mobile-nav" data-mobile-nav="build" hidden>
        <button type="button" data-scene="home">← HOME</button>
        {buildCards.map((card) => <button type="button" data-open={card.id}><span class="lang-en">{card.en}</span><span class="lang-zh">{card.zh}</span></button>)}
      </div>

    </main>

    {detailDialogs.map((item) => (
      <dialog class="pixel-dialog" id={item.id}>
        <article class="dialog-window">
          <header class="window-bar"><span>{item.file}</span><button type="button" data-close aria-label={`Close ${item.id}`}>×</button></header>
          <div class="window-content detail-layout">
            <div class="detail-icon">{item.icon}</div>
            <div>
              <p class="terminal-line">C:\NOAH\PROFILE&gt; OPEN {item.id.toUpperCase()}</p>
              <h2 class="lang-en">{item.enTitle}</h2><h2 class="lang-zh">{item.zhTitle}</h2>
              <p class="lead lang-en">{item.enBody}</p><p class="lead lang-zh">{item.zhBody}</p>
              <div class="chip-row">{item.chips.map((chip) => <span>{chip}</span>)}</div>
              {item.link && <a class="pixel-link" href={item.link} target="_blank" rel="noreferrer"><span class="lang-en">{item.linkEn}</span><span class="lang-zh">{item.linkZh}</span> ↗</a>}
            </div>
          </div>
        </article>
      </dialog>
    ))}

    <dialog class="pixel-dialog wide-dialog" id="imsc">
      <article class="dialog-window">
        <header class="window-bar"><span>IMSC_2026.JPG</span><button type="button" data-close aria-label="Close IMSC">×</button></header>
        <div class="window-content imsc-layout">
          <figure class="imsc-photo"><Image src={imscPhoto} alt="Macau delegation at the fourth International Mathematics Summer Camp" widths={[620, 1000, 1400]} sizes="(max-width: 700px) 90vw, 55vw" format="webp" /></figure>
          <div><p class="terminal-line">EVENT LOG · 2026</p><h2>IMSC</h2><h3 class="lang-en">Math, teamwork and a bigger map.</h3><h3 class="lang-zh">數學、同行，與更大的世界。</h3><p class="lead lang-en">Represented Macau at the 4th International Mathematics Summer Camp.</p><p class="lead lang-zh">代表澳門參與第四屆國際數學夏令營。</p><div class="chip-row"><span>MACAU</span><span>MATH</span><span>2026</span></div></div>
        </div>
      </article>
    </dialog>

    <dialog class="pixel-dialog" id="contact">
      <article class="dialog-window">
        <header class="window-bar"><span>CONTACTS.LNK</span><button type="button" data-close aria-label="Close contact">×</button></header>
        <div class="window-content"><p class="terminal-line">PING NOAH_XU</p><h2><span class="lang-en">Let’s connect.</span><span class="lang-zh">來聊聊。</span></h2><div class="contact-list"><a href="https://github.com/noah200910070082-dotcom" target="_blank" rel="noreferrer"><span>GitHub</span><b>noah200910070082-dotcom</b><em>↗</em></a><a href="https://www.instagram.com/noah_chanwa/" target="_blank" rel="noreferrer"><span>Instagram</span><b>@noah_chanwa</b><em>↗</em></a><button class="copy-handle" type="button" data-copy="Noah107"><span>WeChat</span><b>Noah107</b><em>COPY</em></button><button class="copy-handle" type="button" data-copy="noah_xu_50118"><span>Discord</span><b>noah_xu_50118</b><em>COPY</em></button></div></div>
      </article>
    </dialog>

    <div class="toast" role="status" aria-live="polite"></div>
  </div>

  <script>
    const scenes = Array.from(document.querySelectorAll<HTMLElement>('[data-scene-panel]'));
    const mobileNavs = Array.from(document.querySelectorAll<HTMLElement>('[data-mobile-nav]'));
    const dialogs = Array.from(document.querySelectorAll<HTMLDialogElement>('.pixel-dialog'));
    const toast = document.querySelector<HTMLElement>('.toast');
    const buildDialogIds = new Set(['houkong', 'ai-hub', 'imsc', 'tennis', 'go', 'music']);
    let currentScene = 'home';

    const showToast = (message: string) => {
      if (!toast) return;
      toast.textContent = message;
      toast.classList.add('is-visible');
      window.setTimeout(() => toast.classList.remove('is-visible'), 2100);
    };

    const switchScene = (scene: string, updateHash = true) => {
      currentScene = scene === 'build' ? 'build' : 'home';
      scenes.forEach((panel) => {
        const active = panel.dataset.scenePanel === currentScene;
        panel.classList.toggle('is-active', active);
        panel.setAttribute('aria-hidden', String(!active));
      });
      mobileNavs.forEach((nav) => nav.toggleAttribute('hidden', nav.dataset.mobileNav !== currentScene));
      if (updateHash) history.replaceState(null, '', currentScene === 'build' ? '#build' : '#home');
    };

    const openDialog = (id: string, updateHash = true) => {
      const dialog = document.getElementById(id) as HTMLDialogElement | null;
      if (!dialog) return;
      if (buildDialogIds.has(id)) switchScene('build', false);
      dialogs.forEach((item) => { if (item !== dialog && item.open) item.close(); });
      if (!dialog.open) dialog.showModal();
      if (updateHash) history.replaceState(null, '', `#${id}`);
    };

    document.querySelectorAll<HTMLElement>('[data-scene]').forEach((button) => button.addEventListener('click', () => switchScene(button.dataset.scene || 'home')));
    document.querySelectorAll<HTMLElement>('[data-open]').forEach((button) => button.addEventListener('click', () => openDialog(button.dataset.open || '')));
    document.querySelectorAll<HTMLButtonElement>('[data-close]').forEach((button) => button.addEventListener('click', () => { const dialog = button.closest<HTMLDialogElement>('dialog'); if (dialog) dialog.close(); }));
    dialogs.forEach((dialog) => {
      dialog.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });
      dialog.addEventListener('close', () => history.replaceState(null, '', currentScene === 'build' ? '#build' : '#home'));
    });

    const eggMessages: Record<string, { en: string; zh: string }> = {
      cat: { en: 'Achievement unlocked: the cat approves your click.', zh: '彩蛋解鎖：小貓批准了這次點擊。' },
      tree: { en: 'Growth is a feature, not a deadline.', zh: '成長是一項長期功能，不是一個截止日期。' },
      lake: { en: 'Travel mode: ON. New maps are waiting.', zh: '旅行模式：已開啟。新地圖正在等待。' },
      treehouse: { en: 'Secret workspace found in the treehouse.', zh: '你在樹屋裡發現了一個秘密工作室。' },
      'orange-bird': { en: 'Bird watcher badge: orange edition.', zh: '觀鳥徽章解鎖：橙色版本。' },
      'white-bird': { en: 'This bird has reviewed the pull request.', zh: '這隻鳥已經審閱了 Pull Request。' },
      mushroom: { en: 'Small discoveries still count.', zh: '再小的發現，也值得記錄。' },
      deer: { en: 'Quiet visitor detected at the edge of the map.', zh: '地圖邊緣發現一位安靜的訪客。' },
      'build-cat': { en: 'The hiking cat says: ship it.', zh: '登山小貓說：可以發佈了。' }
    };

    document.querySelectorAll<HTMLElement>('[data-egg]').forEach((button) => button.addEventListener('click', () => { const egg = eggMessages[button.dataset.egg || '']; if (egg) showToast(egg.en); }));

    document.querySelectorAll<HTMLElement>('.image-hotspot, .build-card').forEach((item) => {
      item.addEventListener('pointerdown', () => {
        item.classList.remove('is-popped');
        requestAnimationFrame(() => item.classList.add('is-popped'));
        window.setTimeout(() => item.classList.remove('is-popped'), 360);
      });
    });

    const copyText = async (value: string) => {
      try { await navigator.clipboard.writeText(value); return true; }
      catch {
        const temporary = document.createElement('textarea'); temporary.value = value; temporary.style.position = 'fixed'; temporary.style.opacity = '0'; document.body.appendChild(temporary); temporary.select();
        const legacyCopy = (document as unknown as { execCommand: (command: string) => boolean }).execCommand; const copied = legacyCopy.call(document, 'copy'); temporary.remove(); return copied;
      }
    };
    document.querySelectorAll<HTMLButtonElement>('.copy-handle').forEach((button) => button.addEventListener('click', async () => { const value = button.dataset.copy; if (value && await copyText(value)) showToast('Copied to clipboard.'); }));

    const initial = location.hash.slice(1);
    if (initial === 'build') {
      switchScene('home', false);
      history.replaceState(null, '', '#home');
    } else if (document.getElementById(initial)?.matches('dialog')) openDialog(initial, false);
    else switchScene('home', false);
  </script>
</Layout>
