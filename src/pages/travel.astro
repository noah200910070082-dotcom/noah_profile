  @media (prefers-reduced-motion: reduce) { .travel-ambient, .travel-hero-scene { display: none; }.travel-reveal { opacity: 1; transform: none; }.travel-portal, .travel-card, .campus-note, .travel-hero-art { transform: none !important; transition: none; } }
