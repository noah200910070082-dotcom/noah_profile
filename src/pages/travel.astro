<script>
  const travelHtml = document.documentElement;
  const travelLanguageButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-language-option]'));
  const travelMenuButton = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const travelNavLinks = document.querySelector<HTMLElement>('#travel-nav-links');
  const setTravelLanguage = (language: string, persist = true) => {
    const next = language === 'zh-hans' || language === 'zh-hant' ? language : 'en';
    travelHtml.dataset.language = next;
    travelHtml.lang = next === 'zh-hans' ? 'zh-Hans' : next === 'zh-hant' ? 'zh-Hant' : 'en';
    travelLanguageButtons.forEach((button) => { const active = button.dataset.languageOption === next; button.classList.toggle('is-active', active); button.setAttribute('aria-pressed', String(active)); });
    if (persist) localStorage.setItem('noah-language', next);
  };
  travelLanguageButtons.forEach((button) => button.addEventListener('click', () => setTravelLanguage(button.dataset.languageOption || 'en')));
  travelMenuButton?.addEventListener('click', () => { const open = travelNavLinks?.classList.toggle('is-open') ?? false; travelMenuButton.setAttribute('aria-expanded', String(open)); travelMenuButton.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation'); });
  travelNavLinks?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => { travelNavLinks.classList.remove('is-open'); travelMenuButton?.setAttribute('aria-expanded', 'false'); }));

  const travelObserver = new IntersectionObserver((entries) => entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('is-visible'); travelObserver.unobserve(entry.target); } }), { threshold: 0.1 });
  document.querySelectorAll('.travel-reveal').forEach((element) => travelObserver.observe(element));

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const finePointer = window.matchMedia('(pointer: fine)').matches;
  if (!prefersReduced && finePointer) {
    document.querySelectorAll<HTMLElement>('.travel-tilt').forEach((card) => {
      const strength = Number(card.dataset.tiltStrength || 9);
      card.addEventListener('pointermove', (event) => { const bounds = card.getBoundingClientRect(); const x = Math.min(1, Math.max(0, (event.clientX - bounds.left) / bounds.width)); const y = Math.min(1, Math.max(0, (event.clientY - bounds.top) / bounds.height)); card.classList.add('is-interacting'); card.style.setProperty('--tilt-x', `${(0.5 - y) * strength}deg`); card.style.setProperty('--tilt-y', `${(x - 0.5) * strength}deg`); });
      card.addEventListener('pointerleave', () => { card.classList.remove('is-interacting'); card.style.setProperty('--tilt-x', '0deg'); card.style.setProperty('--tilt-y', '0deg'); });
    });
  }

  const travelViewer = document.querySelector<HTMLElement>('.travel-viewer');
  const travelViewerImage = document.querySelector<HTMLImageElement>('.travel-viewer-image');
  const travelViewerCaption = document.querySelector<HTMLElement>('#travel-viewer-caption');
  const travelViewerMeta = document.querySelector<HTMLElement>('.travel-viewer-meta');
  const travelViewerCounter = document.querySelector<HTMLElement>('.travel-viewer-counter');
  const travelCards = Array.from(document.querySelectorAll<HTMLButtonElement>('.travel-card'));
  let travelIndex = 0;
  const showTravelImage = (index: number) => { if (!travelViewer || !travelViewerImage || !travelViewerCaption || !travelViewerMeta || !travelViewerCounter || !travelCards.length) return; travelIndex = (index + travelCards.length) % travelCards.length; const card = travelCards[travelIndex]; const image = card.querySelector('img'); if (!image) return; travelViewerImage.src = image.currentSrc || image.src; travelViewerImage.alt = card.dataset.alt || ''; travelViewerCaption.textContent = card.dataset.caption || ''; travelViewerMeta.textContent = card.dataset.meta || ''; travelViewerCounter.textContent = `${String(travelIndex + 1).padStart(2, '0')} / ${String(travelCards.length).padStart(2, '0')}`; travelViewer.hidden = false; travelViewer.setAttribute('aria-hidden', 'false'); requestAnimationFrame(() => travelViewer.classList.add('is-open')); document.body.classList.add('viewer-open'); };
  const closeTravelViewer = () => { if (!travelViewer) return; travelViewer.classList.remove('is-open'); travelViewer.setAttribute('aria-hidden', 'true'); document.body.classList.remove('viewer-open'); window.setTimeout(() => { travelViewer.hidden = true; }, 220); };
  travelCards.forEach((card, index) => card.addEventListener('click', () => showTravelImage(index)));
  document.querySelectorAll<HTMLElement>('[data-travel-close]').forEach((button) => button.addEventListener('click', closeTravelViewer));
  document.querySelector<HTMLElement>('[data-travel-prev]')?.addEventListener('click', () => showTravelImage(travelIndex - 1));
  document.querySelector<HTMLElement>('[data-travel-next]')?.addEventListener('click', () => showTravelImage(travelIndex + 1));
  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeTravelViewer();
    if (!travelViewer?.classList.contains('is-open')) return;
    if (event.key === 'ArrowLeft') showTravelImage(travelIndex - 1);
    if (event.key === 'ArrowRight') showTravelImage(travelIndex + 1);
  });
</script>
